# loops.env — install.sh 가 머신별로 자동 생성한다 (gitignore). 직접 수정도 가능.
# 도구 경로는 보통 install.sh 자동 탐지로 충분하고, 아래 2개만 취향껏 손보면 된다.

# node / claude / gh 가 들어있는 디렉토리들 (':' 구분). nohup/cmux 패널은 PATH가 빈약해서 필요.
LOOPS_PATH_PREPEND=""

# 도구 절대경로 (install.sh 자동 탐지)
CLAUDE_BIN=""
CMUX_BIN=""
GH_BIN=""

# cmux 앱 번들 id (osascript activate 용)
CMUX_BUNDLE_ID="com.cmuxterm.app"

# 새 loop worker worktree 베이스 → $WORKTREE_BASE/loop-<id>
WORKTREE_BASE="$HOME/LTH"

# AI 빌더 / create-loop 의 기본 repo (모노레포면 편함). 없으면 빈값으로 두고 loop마다 지정.
DEFAULT_REPO=""

# 대시보드 포트
LOOPS_PORT="8422"

# (선택) 폰 원격제어 — `tailscale cert`로 이 노드의 tailnet 정식 인증서를 받아, 대시보드 서버가
#   tailscale IP에 HTTPS 리스너를 직접 연다(내 tailnet 전용, LAN/공개 노출 없음, `tailscale serve` 미변경).
#   HTTPS인 이유: 폰 웹푸시 알림은 secure context 필수. 1=켬.
#   'loopctl remote' / 'loopctl dashboard remote' / 대시보드 ⋯→'📱 폰 원격 접속'이 이 값을 토글한다.
#   폰에도 Tailscale 앱이 같은 tailnet 으로 로그인돼 있어야 접속됨.
LOOPS_REMOTE="0"

# (선택) 원격 접속 비밀번호 "user:pass" — 설정 시 비-loopback(원격) 요청에 Basic auth 요구(선택적 방어).
#   tailnet 자체가 사설 경계라 보통 불필요. 공개 cloudflare 터널('loopctl remote cloudflare')엔 자동 생성됨.
LOOPS_REMOTE_AUTH=""

# (선택) 웹푸시 VAPID 주제 — 잘 형성된 https:// 또는 mailto: 면 됨(해석될 필요 없음). 비우면 기본값.
LOOPS_PUSH_SUBJECT=""

# (선택) Telegram 원격 봇 — 폰으로 push 알림 + 결정·취소·재실행.
#   @BotFather 로 봇 생성 후 토큰만 넣으면, 'loopctl bot' 실행 → 봇에게 아무 메시지 보내면
#   chat-id 가 자동 페어링되어 아래 TELEGRAM_CHAT_ID 에 채워진다(수동 입력 불필요).
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
