#!/bin/zsh
# Loops 플랫폼 제어 CLI. (대시보드 버튼과 동일 — 서버/디스패처는 cmux 패널에서 실행되어야 함)
# usage: loopctl dashboard|bot|start|stop|pause|resume|run-now <loop>|update|worktrees <loop>|cleanup <loop>|remote|status
source "${0:A:h}/bin/_common.sh"
ROOT="$LOOPS_HOME"; STATE=$ROOT/state; PID=$STATE/dispatcher.pid; PAUSED=$STATE/PAUSED
CMUX="$CMUX_BIN"
mkdir -p "$STATE"
alive(){ [[ -f "$PID" ]] && kill -0 "$(cat "$PID" 2>/dev/null)" 2>/dev/null; }
# loops.env 키 갱신(추가/치환) — 코드베이스 단일 원천(bin/env-file.mjs) 재사용. ROOT는 argv로 주입(모듈 오유도 방지).
set_loops_env(){ node --input-type=module -e 'const {setEnvVar}=await import(process.argv[1]+"/bin/env-file.mjs");setEnvVar(process.argv[1],process.argv[2],process.argv[3])' "$ROOT" "$1" "$2"; }
# tailscale MagicDNS fqdn → 대시보드 원격 HTTPS URL. 미실행/로그아웃/미설치/무-MagicDNS면 비0 종료(무음 fallback 없음).
# HTTPS인 이유: 웹푸시(secure context) + 정식 인증서. 인증서 SAN=fqdn 이라 IP가 아닌 dnsName 필수.
remote_url(){ command -v tailscale >/dev/null || return 5; tailscale status --json 2>/dev/null | LOOPS_PORT="${LOOPS_PORT:-8422}" node -e 'let d="";process.stdin.on("data",c=>d+=c).on("end",()=>{try{const j=JSON.parse(d);if(j.BackendState!=="Running")process.exit(3);const dns=String((j.Self&&j.Self.DNSName)||"").replace(/\.$/,"");if(!dns)process.exit(4);process.stdout.write("https://"+dns+":"+process.env.LOOPS_PORT+"/")}catch(e){process.exit(2)}})'; }
# worktrees <loop> — 읽기전용 진단. 종료된 이슈의 잔류 worktree를 표면화(삭제는 안 함, 사람 몫).
worktrees(){
  local loop="${1:-}"
  [[ -z "$loop" ]] && { echo "usage: loopctl worktrees <loop>"; return 1; }
  local cfg="$ROOT/loops/$loop/config.json"
  [[ -f "$cfg" ]] || { echo "loop '$loop' config 없음 ($cfg) — worktree 목록 비어있음"; return 0; }
  local repo prefix; repo="$(cfgval "$cfg" repo)"; prefix="$(cfgval "$cfg" worktreePrefix)"
  [[ -z "$repo" || -z "$prefix" ]] && { echo "config에 repo/worktreePrefix 없음 — 진단 불가"; return 0; }
  # snapshot(slug→id·state) 로드. 없으면 깨지지 말고 ? 표기.
  local snap="$ROOT/loops/$loop/state/snapshot.json"
  typeset -A SNAPID SNAPST; local sl id st
  if [[ -f "$snap" ]]; then
    while IFS=$'\t' read -r sl id st; do SNAPID[$sl]="$id"; SNAPST[$sl]="$st"; done < <(
      node -e 'const s=JSON.parse(require("fs").readFileSync(process.argv[1]));for(const i of (s.issues||[])){const g=String(i.id||"").toLowerCase().replace(/[^a-z0-9]+/g,"-").replace(/-+$/,"");process.stdout.write(g+"\t"+(i.id||"?")+"\t"+(i.state||"?")+"\n")}' "$snap")
  else
    echo "ℹ️ snapshot 없음 ($snap) — state는 ? 로 표기"
  fi
  echo "🧹 worktrees — $loop  (repo: $repo)"
  # git worktree 목록에서 worker worktree(${prefix}-<slug>)만 추림. orchestrator(=${prefix})·main은 제외.
  local -a paths branches; local wt="" br="?" line
  while IFS= read -r line; do
    case "$line" in
      "worktree "*) [[ -n "$wt" ]] && { paths+=("$wt"); branches+=("$br"); }; wt="${line#worktree }"; br="?" ;;
      "branch refs/heads/"*) br="${line#branch refs/heads/}" ;;
      "detached") br="(detached)" ;;
    esac
  done <<< "$(git -C "$repo" worktree list --porcelain 2>/dev/null)"
  [[ -n "$wt" ]] && { paths+=("$wt"); branches+=("$br"); }
  local count=0 i p b slug suffix
  for ((i=1; i<=${#paths[@]}; i++)); do
    p="${paths[$i]}"; b="${branches[$i]}"
    case "$p" in
      "${prefix}-"*)
        slug="${p#"$prefix"-}"; id="${SNAPID[$slug]:-?}"; st="${SNAPST[$slug]:-?}"; suffix=""
        [[ "$st" == "Done" || "$st" == "Canceled" ]] && suffix="  🧹 정리 후보"
        printf '%s  %s  %s  %s%s\n' "$p" "$b" "$id" "$st" "$suffix"
        count=$((count+1)) ;;
    esac
  done
  if (( count == 0 )); then
    echo "(worktreePrefix '${prefix}-…' 로 시작하는 worktree 없음)"
  else
    echo "정리하려면: git -C \"$repo\" worktree remove <경로> && git -C \"$repo\" branch -D <branch>"
  fi
}
case "${1:-status}" in
  dashboard) # `loopctl dashboard remote` → 부팅 시 tailscale IP에도 바인딩(폰 원격). loops.env LOOPS_REMOTE=1 로 영속.
          [[ "${2:-}" == "remote" || "${2:-}" == "--remote" ]] && { set_loops_env LOOPS_REMOTE 1; REMOTE_REQ=1; }
          "$ROOT/bin/spawn-panel.sh" "$ROOT" "node --watch $ROOT/dashboard-server.mjs" "📊 loops dashboard" >/dev/null || { echo "⚠️ 대시보드 패널 기동 실패 — cmux 앱 상태 확인"; exit 1; }
          sleep 1; echo "📊 http://localhost:${LOOPS_PORT:-8422} (cmux 패널, hot-reload)"
          if [[ -n "${REMOTE_REQ:-}" ]]; then
            url="$(remote_url)" && echo "📱 원격(폰): $url  — 대시보드 ⋯ → '📱 폰 원격 접속' 에서 QR 스캔" \
              || echo "⚠️ tailscale 미실행/로그아웃 — 'tailscale up' 후 대시보드 ⋯ → '📱 폰 원격 접속' 에서 다시 켜세요"
          fi;;
  bot) # Telegram 원격 알림·제어 브리지 (cmux 패널). 대시보드가 떠 있어야 함(/api/status 폴링).
       if [[ -z "${TELEGRAM_BOT_TOKEN:-}" ]]; then
         echo "🤖 TELEGRAM_BOT_TOKEN 없음 — 원격 봇 셋업:"
         echo "   1) 텔레그램에서 @BotFather → /newbot → 토큰 복사"
         echo "   2) print -r -- 'TELEGRAM_BOT_TOKEN=<토큰>' >> \"$ROOT/loops.env\""
         echo "   3) loopctl bot 다시 → 봇에게 아무 메시지 (chat-id 자동 페어링)"
         exit 1
       fi
       curl -s -o /dev/null --max-time 2 "http://localhost:${LOOPS_PORT:-8422}/" 2>/dev/null || echo "⚠️  대시보드 미실행 — 'loopctl dashboard' 먼저 (봇은 /api/status를 폴링함)"
       rm -f "$STATE/STOPPED.bot"   # "켜라"는 의도 — supervisor 감독 대상으로 복귀
       "$ROOT/bin/spawn-panel.sh" "$ROOT" "node --watch $ROOT/bin/notify-bot.mjs" "🤖 loops bot" >/dev/null || { echo "⚠️ 봇 패널 기동 실패 — cmux 앱 상태 확인"; exit 1; }
       sleep 1
       [[ -z "${TELEGRAM_CHAT_ID:-}" ]] && echo "🤖 봇 기동 (cmux 패널) — 텔레그램에서 봇에게 아무 메시지 보내 페어링하세요" || echo "🤖 봇 기동 (cmux 패널, chat 연결됨)";;
  start)  rm -f "$STATE/STOPPED.dispatcher"   # "켜라"는 의도 — supervisor 감독 대상으로 복귀
          alive && { echo "이미 running (pid $(cat $PID))"; exit 0; }
          # 디스패처만 큐 잔류 허용(SPAWN_PANEL_QUEUE_OK — 이중기동 가드 전제): cmux 백그라운드면 ⏳ 탭 1개를 남겨
          # 전면화 시 자동 발화. exit 2 = 큐 잔류(성공도 실패도 아님 — 대기).
          SPAWN_PANEL_QUEUE_OK=1 "$ROOT/bin/spawn-panel.sh" "$ROOT" "$ROOT/bin/dispatch.sh" "🔁 loops dispatcher" >/dev/null
          rc=$?
          if (( rc == 2 )); then echo "🕐 디스패처 큐 대기(⏳) — cmux 창을 화면에 띄우면 자동 시작됩니다"; exit 0; fi
          (( rc != 0 )) && { echo "⚠️ 디스패처 패널 기동 실패 — cmux 앱 상태 확인"; exit 1; }
          sleep 1.5
          echo "▶ 디스패처 시작 (cmux 패널, pid $(cat $PID 2>/dev/null))";;
  stop)   touch "$STATE/STOPPED.dispatcher"   # 의도적 정지 마커 — supervisor가 "죽음"으로 오인해 재기동하지 않도록
          alive && { kill "$(cat $PID)" 2>/dev/null; echo "⏹ 중지"; } || echo "안 돌고있음";;
  pause)  touch "$PAUSED"; echo "⏸ 전역 일시정지";;
  resume) rm -f "$PAUSED"; echo "▶ 재개";;
  run-now) "$ROOT/bin/spawn-panel.sh" "$ROOT" "$ROOT/bin/spawn-orchestrator.sh ${2:?loop-id 필요}" >/dev/null || { echo "⚠️ 패널 기동 실패 — cmux 앱 상태 확인"; exit 1; }
          echo "⚡ ${2} 1사이클 발사";;
  update) # 엔진을 origin 추적 브랜치로 즉시 fast-forward(ff-only, no-force). 디스패처가 켜져 있으면 다음 idle 사이클에 자동 재실행되어 반영됨.
          "$ROOT/bin/self-update.sh"; rc=$?
          if (( rc == 10 )); then
            alive && echo "↻ 디스패처가 다음 idle 사이클(≤${LOOPS_UPDATE_INTERVAL:-600}s)에 새 코드로 자동 재실행됩니다. 즉시 반영하려면: loopctl stop && loopctl start"
          fi;;
  worktrees) worktrees "${2:-}";;
  cleanup) # 확정-종료(Done/Canceled·머지/닫힘 PR) worktree·탭만 정리. `--dry` 면 삭제 없이 대상만 표시.
           [[ "${3:-}" == "--dry" ]] && export CLEANUP_DRY_RUN=1
           "$ROOT/bin/cleanup-terminal.sh" "${2:?usage: loopctl cleanup <loop> [--dry]}";;
  supervisor) # 프로세스 감독자 — launchd(60s)로 supervisor.sh를 돌려 죽은 디스패처/대시보드/봇을 자동 재기동. install|remove|status|run
          SUP_PLIST="$HOME/Library/LaunchAgents/com.loops.supervisor.plist"; SUP_LABEL="com.loops.supervisor"
          case "${2:-status}" in
            install)
              [[ "$(uname)" == "Darwin" ]] || { echo "launchd는 macOS 전용 — 다른 OS는 cron 등록: * * * * * $ROOT/bin/supervisor.sh >> $ROOT/state/supervisor.log 2>&1"; exit 1; }
              mkdir -p "$HOME/Library/LaunchAgents" "$STATE"
              cat > "$SUP_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>$SUP_LABEL</string>
  <key>ProgramArguments</key><array>
    <string>/bin/zsh</string>
    <string>$ROOT/bin/supervisor.sh</string>
  </array>
  <key>StartInterval</key><integer>60</integer>
  <key>RunAtLoad</key><true/>
  <key>StandardOutPath</key><string>$ROOT/state/supervisor.log</string>
  <key>StandardErrorPath</key><string>$ROOT/state/supervisor.log</string>
</dict></plist>
PLIST
              launchctl bootout "gui/$(id -u)/$SUP_LABEL" 2>/dev/null   # 재설치 멱등 — 기존 등록 제거 후 재등록
              if launchctl bootstrap "gui/$(id -u)" "$SUP_PLIST"; then
                echo "🩹 supervisor 등록 — 60초마다 감시·재기동 (로그: state/supervisor.log)"
                echo "   · 의도적 정지(loopctl stop / 대시보드 ⏹)는 STOPPED 마커로 존중 — 재기동 안 함"
                echo "   · crash-loop(10분 내 3회)이면: 직전 self-update 원인 추정 시 롤백, 아니면 30분 백오프+알림"
              else
                echo "⚠️ launchctl bootstrap 실패 — 'launchctl bootstrap gui/$(id -u) $SUP_PLIST' 직접 실행해 에러를 확인하세요"; exit 1
              fi;;
            remove) launchctl bootout "gui/$(id -u)/$SUP_LABEL" 2>/dev/null; rm -f "$SUP_PLIST"; echo "supervisor 제거됨 (launchd 등록·plist 삭제)";;
            run) exec "$ROOT/bin/supervisor.sh";;
            status|*)
              if launchctl print "gui/$(id -u)/$SUP_LABEL" >/dev/null 2>&1; then echo "● supervisor 등록됨 (launchd, 60s)"; else echo "○ supervisor 미등록 — 'loopctl supervisor install'"; fi
              [[ -f "$STATE/supervisor.log" ]] && { echo "─ 최근 로그:"; tail -5 "$STATE/supervisor.log"; };;
          esac;;
  doctor) # 전제도구·설정·런타임 헬스체크 (온보딩 후 점검).
          echo "🩺 loopctl doctor"
          source "$ROOT/bin/preflight.sh"; loops_preflight check
          echo "⚙️  설정:"
          [[ -f "$ROOT/loops.env" ]] && echo "  ✅ loops.env" || echo "  ⚠️  loops.env 없음 — ./install.sh"
          [[ -n "${LINEAR_API_KEY:-}" ]] && echo "  ✅ LINEAR_API_KEY 설정됨" || echo "  ⚠️  LINEAR_API_KEY 없음 — 대시보드 ⚙️ 에서 입력(정리 신호·백로그 발굴에 필요)"
          if [[ -n "${TELEGRAM_BOT_TOKEN:-}" ]]; then
            [[ -n "${TELEGRAM_CHAT_ID:-}" ]] && echo "  ✅ Telegram 봇 설정됨 (chat 연결됨)" || echo "  ⏳ Telegram 봇 토큰 있음 — 페어링 대기('loopctl bot' 후 봇에게 메시지)"
            pgrep -f "$ROOT/bin/notify-bot.mjs" >/dev/null && echo "  ● 봇 running" || echo "  ○ 봇 stopped — 'loopctl bot'"
          else
            echo "  ○ Telegram 봇 미설정 (선택) — 폰 원격제어 원하면 'loopctl bot'"
          fi
          command -v loopctl >/dev/null && echo "  ✅ loopctl PATH 등록 ($(command -v loopctl))" || echo "  ⚠️  loopctl PATH 미등록 — ./install.sh 재실행 또는 ~/.local/bin 심볼릭"
          echo "🚦 런타임:"
          if alive; then echo "  ● dispatcher running (pid $(cat $PID))"; else echo "  ○ dispatcher stopped — 'loopctl start'"; fi
          if [[ "$(uname)" == "Darwin" ]]; then
            launchctl print "gui/$(id -u)/com.loops.supervisor" >/dev/null 2>&1 && echo "  ✅ supervisor 등록됨 (죽으면 자동 재기동)" || echo "  ○ supervisor 미등록 — 'loopctl supervisor install' (디스패처/대시보드/봇 사망 시 자동 재기동)"
          fi
          [[ -f "$PAUSED" ]] && echo "  ⏸ 전역 PAUSED"
          if curl -s -o /dev/null --max-time 2 "http://localhost:${LOOPS_PORT:-8422}/" 2>/dev/null; then echo "  ✅ 대시보드 응답 (http://localhost:${LOOPS_PORT:-8422})"; else echo "  ○ 대시보드 미응답 — 'loopctl dashboard'"; fi
          echo "📁 loops: $(ls "$ROOT/loops" 2>/dev/null | tr '\n' ' ')";;
  help|-h|--help)
          PORTV="${LOOPS_PORT:-8422}"
          cat <<EOF
Loops — 멀티루프 자율 에이전트 플랫폼. 헤드리스 Claude Code 워커가 도메인별로 작업을 발굴→구현→PR 한다. **머지는 사람.**

런타임:
  loopctl dashboard [remote]   대시보드 (http://localhost:$PORTV, cmux 패널). remote → 폰 원격(tailscale)도 켜서 시작
  loopctl start | stop         전역 디스패처 시작 / 중지
  loopctl pause | resume       전역 일시정지 / 재개
  loopctl status               디스패처·루프 상태
  loopctl run-now <loop>       루프 1사이클 즉시 발사
  loopctl update               엔진을 origin 최신으로 갱신 (ff-only) — 디스패처는 idle마다 자동으로도 수행

정리:
  loopctl worktrees <loop>         종료 이슈 잔여 worktree 진단 (읽기전용)
  loopctl cleanup <loop> [--dry]   종료(Done/Canceled) worktree·탭·브랜치 정리

온보딩 / 점검:
  ./install.sh                 최초 설치 (전제도구 점검·설치, loopctl 전역 등록)
  loopctl doctor               전제도구·설정·런타임 헬스체크
  loopctl supervisor install   프로세스 감독자(launchd) — 죽은 디스패처/대시보드/봇 자동 재기동 + crash-loop 롤백
  loopctl help                 이 도움말

원격:
  loopctl bot                  Telegram 봇 — 폰으로 push 알림 + 결정·취소·재실행 (cmux 패널)
  loopctl remote [tailscale]   폰 원격제어 ON — 대시보드를 tailscale IP에도 바인딩(내 tailnet 전용). ⋯→'📱 폰 원격 접속' 에서 QR
  loopctl remote off           폰 원격 OFF (로컬 127.0.0.1 접속은 유지)

안전 불변식: 엔진은 절대 merge / deploy / force-push 하지 않는다. 워커는 PR만 연다.
루프 추가: 대시보드 '+ 새 loop' (AI 생성) 또는 examples/ 복사 → loops/<id>/
EOF
          ;;
  remote) # 대시보드 원격 노출. 기본=tailscale(내 tailnet 전용, 폰에서 QR로 접속). `off`로 끄기.
    case "${2:-tailscale}" in
      tailscale|ts|"")  # tailscale IP에 추가 바인딩(서버가 처리) — 대시보드 떠 있으면 라이브 토글, 아니면 부팅 플래그.
        command -v tailscale >/dev/null || { echo "tailscale 없음 — https://tailscale.com/download (또는 'brew install tailscale')"; exit 1; }
        url="$(remote_url)" || { echo "⚠️ tailscale가 실행/로그인 상태가 아닙니다 — 'tailscale up' 후 다시 시도"; exit 1; }
        if curl -s -o /dev/null --max-time 2 "http://localhost:${LOOPS_PORT:-8422}/" 2>/dev/null; then
          curl -s --max-time 5 -XPOST "http://localhost:${LOOPS_PORT:-8422}/api/control" -H 'content-type: application/json' -d '{"action":"remote-on"}' >/dev/null \
            && echo "📱 원격 켜짐 (대시보드 라이브 적용, 재시작 불필요)." || echo "⚠️ 대시보드 제어 호출 실패 — 대시보드 로그 확인"
        else
          set_loops_env LOOPS_REMOTE 1
          echo "📱 LOOPS_REMOTE=1 저장 — 'loopctl dashboard' 로 대시보드를 띄우면 자동으로 원격이 켜집니다."
        fi
        echo "   주소: $url"
        echo "   폰에서 위 주소를 열거나, 대시보드 ⋯ → '📱 폰 원격 접속' 에서 QR 스캔 (폰도 같은 tailnet Tailscale 로그인 필요)."
        [[ -n "${LOOPS_REMOTE_AUTH:-}" ]] && echo "   🔒 비밀번호: ${LOOPS_REMOTE_AUTH%%:*} / ${LOOPS_REMOTE_AUTH#*:}"
        echo "   끄기: loopctl remote off  (또는 대시보드 ⋯ → '📱 폰 원격 접속' → ■ 끄기)";;
      off)  # 원격 리스너 닫기 + 부팅 플래그 해제. 127.0.0.1(로컬 cmux)은 그대로.
        curl -s -o /dev/null --max-time 2 "http://localhost:${LOOPS_PORT:-8422}/" 2>/dev/null \
          && curl -s --max-time 5 -XPOST "http://localhost:${LOOPS_PORT:-8422}/api/control" -H 'content-type: application/json' -d '{"action":"remote-off"}' >/dev/null
        set_loops_env LOOPS_REMOTE 0
        echo "📴 원격 꺼짐 (LOOPS_REMOTE=0)";;
      *) echo "usage: loopctl remote [tailscale|off]"; exit 1;;
    esac;;
  status) if alive; then echo "● running (pid $(cat $PID))"; else echo "○ stopped"; fi; [[ -f $PAUSED ]] && echo "⏸ PAUSED"; echo "loops: $(ls "$ROOT/loops" 2>/dev/null | tr '\n' ' ')";;
  *) echo "알 수 없는 명령: ${1:-}"; echo; exec "$0" help;;
esac
